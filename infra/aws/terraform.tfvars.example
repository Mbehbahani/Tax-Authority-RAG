project_name          = "tax-rag"
environment           = "dev"
aws_region            = "eu-central-1"

vpc_cidr              = "10.42.0.0/16"
public_subnet_cidrs   = ["10.42.1.0/24", "10.42.2.0/24"]
private_subnet_cidrs  = ["10.42.11.0/24", "10.42.12.0/24"]

artifacts_bucket_name = "tax-rag-dev-artifacts-example"

opensearch_instance_type = "t3.small.search"
opensearch_volume_size   = 20
redis_node_type          = "cache.t4g.micro"
opensearch_master_user_name     = "taxragadmin"
opensearch_master_user_password = "replace-me-locally"

enable_opensearch = true
enable_redis      = true