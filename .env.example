APP_ENV=local
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=tax-rag-chunks-v1

# Retrieval backend: "memory" (default for laptops) or "opensearch".
# The "memory" backend is a faithful fake that obeys the same auth filter
# contract as OpenSearch DLS, so switching between them does not change
# application-level tests. See docs/STAGE_1_IMPLEMENTATION_REPORT.md.
RETRIEVAL_BACKEND=memory  # Options: memory, opensearch

# OpenSearch Backend Configuration
# Keep real OpenSearch credentials out of this file - use local .env files or secrets managers
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=tax-rag-chunks-v1  # Options: memory, opensearch

# AWS / Bedrock configuration.
# Keep real AWS credentials out of this file. Use AWS profiles, IAM roles, SSO,
# environment-specific secret managers, or local .env files that are not committed.
AWS_REGION=eu-central-1
BEDROCK_REGION=eu-central-1
AWS_PROFILE=tax-rag-dev
AWS_ACCOUNT_ID=780822965578

# Model IDs verified as listed in Bedrock model catalog for eu-central-1.
# Runtime invocation access may still need to be enabled/tested in the AWS account.
BEDROCK_GENERATION_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0
BEDROCK_FAST_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_JUDGE_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-v4:0
BEDROCK_FALLBACK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_RERANK_MODEL_ID=cohere.rerank-v3-5:0

SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_SAFE_THRESHOLD=0.95

# Optional local/development tuning.
RETRIEVAL_LEXICAL_TOP_K=50
RETRIEVAL_VECTOR_TOP_K=50
RETRIEVAL_FUSED_CANDIDATES=80
RERANK_MAX_CANDIDATES=60
FINAL_CONTEXT_CHUNKS=8
HNSW_M=32
HNSW_EF_CONSTRUCTION=256
HNSW_EF_SEARCH=128

# Evaluation / model-routing configuration.
EVALUATION_FRAMEWORK=deepeval
MODEL_ROUTING_EVAL_ENABLED=true
HAIKU_ALLOWED_FAITHFULNESS_DELTA_VS_SONNET=0.02
CITATION_COMPLETENESS_MIN=1.0
CITATION_ACCURACY_MIN=1.0
RBAC_LEAKAGE_COUNT_MAX=0
TTFT_P95_SECONDS_MAX=1.5

# Local sample data paths.
SAMPLE_CORPUS_MANIFEST=sample_corpus/manifest.json
SAMPLE_USERS_FILE=sample_requests/users.json
SAMPLE_QUERIES_FILE=sample_requests/queries.json
SAMPLE_EXPECTED_BEHAVIORS_FILE=sample_requests/expected_behaviors.json

# Observability / tracing.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=tax-rag-assessment
AUDIT_LOG_ENABLED=true

# Never commit real secrets such as AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY.

